{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "16dee767c8994d0f82af16609a06003b",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "SobelDepthFilter (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -888.0,
            "y": 108.0,
            "width": 250.0,
            "height": 149.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "8ef183e6acec4b2284e1f8c9b0b2a238"
        },
        {
            "m_Id": "687e411acd61416eb406587502cd36be"
        },
        {
            "m_Id": "0c57f64cd6214647ac280d4f71098354"
        },
        {
            "m_Id": "d4fe5dcb765240699171178641b5606a"
        },
        {
            "m_Id": "cea4af3c15574549832a3febca70842b"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "SobelDepthFilter",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "// 1. Importamos a biblioteca de profundidade da URP para a função SampleSceneDepth funcionar\r\n#ifndef SHADERGRAPH_PREVIEW\r\n    #include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/DeclareDepthTexture.hlsl\"\r\n#endif\r\n\r\n// 2. Multiplicamos o tamanho do pixel pela espessura da linha\r\nfloat2 offset = Texel * Thickness;\r\n\r\n#if defined(SHADERGRAPH_PREVIEW)\r\n    // Se estivermos na tela de preview do Shader Graph, não fazemos nada para evitar erros\r\n    Edge = 0;\r\n#else\r\n    // 3. Lemos a profundidade da cena nos 4 vizinhos (Cima, Baixo, Direita, Esquerda)\r\n    float up = LinearEyeDepth(SampleSceneDepth(UV + float2(0, offset.y)), _ZBufferParams);\r\n    float down = LinearEyeDepth(SampleSceneDepth(UV - float2(0, offset.y)), _ZBufferParams);\r\n    float right = LinearEyeDepth(SampleSceneDepth(UV + float2(offset.x, 0)), _ZBufferParams);\r\n    float left = LinearEyeDepth(SampleSceneDepth(UV - float2(offset.x, 0)), _ZBufferParams);\r\n\r\n    // 4. Calculamos a diferença total de profundidade entre os lados\r\n    float diff = abs(right - left) + abs(up - down);\r\n\r\n    // 5. Se a diferença for maior que o Threshold, desenha a linha (1), senão fica transparente (0)\r\n    Edge = step(Threshold, diff);\r\n#endif"
}

